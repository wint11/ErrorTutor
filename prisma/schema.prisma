generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  username  String   @unique
  password  String
  grade     String?
  level     String?
  textbookVersion String? @default("人教版")
  role            String   @default("STUDENT") // 可以是 "STUDENT" 或 "TEACHER"
  requirePasswordChange Boolean @default(false)
  classId         String?  // 如果是学生，可以归属一个班级
  class           Class?   @relation("StudentClass", fields: [classId], references: [id])
  createdClasses  Class[]  @relation("TeacherClasses")
  aiPortrait      String?
  aiPortraitUpdatedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tutoringSessions TutoringSession[]
  mistakes         MistakeRecord[]
  appUploads       AppUpload[]
  masteredNodes    UserMasteredNode[]
  exerciseSubmissions ExerciseSubmission[]
}

model Class {
  id        String   @id @default(uuid())
  name      String
  teacherId String
  teacher   User     @relation("TeacherClasses", fields: [teacherId], references: [id])
  students  User[]   @relation("StudentClass")
  exercises Exercise[]
  createdAt DateTime @default(now())
}

model Exercise {
  id             String   @id @default(uuid())
  title          String
  content        String
  knowledgePoint String?  // 绑定的知识点
  classId        String
  class          Class    @relation(fields: [classId], references: [id])
  dueDate        DateTime?
  createdAt      DateTime @default(now())
  
  submissions ExerciseSubmission[]
}

model ExerciseSubmission {
  id             String   @id @default(uuid())
  exerciseId     String
  exercise       Exercise @relation(fields: [exerciseId], references: [id])
  studentId      String
  student        User     @relation(fields: [studentId], references: [id])
  content        String?  // 学生的作答内容
  isCorrect      Boolean  @default(false)
  mistakeSummary String?  // AI 生成的错误总结，用于交叉练习
  createdAt      DateTime @default(now())
}

model UserMasteredNode {
  id             String   @id @default(uuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  nodeId         String
  errorCount     Int      @default(0)
  totalPracticed Int      @default(0)
  isMastered     Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @default(now()) @updatedAt

  @@unique([userId, nodeId])
}

model TutoringSession {
  id             String   @id @default(uuid())
  groupId        String?  // 用于将多次“再来一题”或批量生成的题目关联在一起
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  problemText    String
  knowledgePoint String?  // AI 解析出的核心知识点
  topic          String?  // 选定的知识点名称（用于查漏补缺和专项突破）
  mistakeText    String?  // 选定的错题内容（用于错题复习）
  mode           String   @default("通用辅导")
  difficulty     String?  // 题目难度
  status         String   @default("IN_PROGRESS") // 可以是 PENDING, IN_PROGRESS, COMPLETED
  currentStep    Int      @default(0)
  timeLimit      Int?     // 限时挑战的时间（分钟），如果不限时则为 null
  exerciseId     String?  // 关联的班级练习任务 ID（如果有）
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  messages       ChatMessage[]
}

model ChatMessage {
  id        String          @id @default(uuid())
  sessionId String
  session   TutoringSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role      String
  text      String
  createdAt DateTime        @default(now())
}

model MistakeRecord {
  id             String   @id @default(uuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  problemText    String
  errorType      String?
  knowledgePoint String?
  status         String   @default("待复习")
  createdAt      DateTime @default(now())
}

model AppUpload {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  questionId  String
  grade       String
  imageUrl    String
  ocrText     String?
  status      String   @default("pending")
  createdAt   DateTime @default(now())
}

model ProblemBank {
  id        String   @id @default(uuid())
  grade     String
  content   String
  answer    String?
  createdAt DateTime @default(now())
}

model RawProblem {
  id          String   @id @default(uuid())
  questionId  String   @unique
  grade       String
  imageUrl    String
  ocrText     String?
  ocrLines    String?
  processedContent String?
  status      String   @default("pending")
  createdAt   DateTime @default(now())
}
