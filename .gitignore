# ==========================================
# 数智学堂 - Git 忽略文件配置
# ==========================================

# ------------------------------------------
# 依赖
# ------------------------------------------
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz
package-lock.json
yarn.lock
pnpm-lock.yaml

# ------------------------------------------
# 测试
# ------------------------------------------
/coverage
.nyc_output

# ------------------------------------------
# Next.js 构建输出
# ------------------------------------------
/.next/
/out/
/build
/dist

# ------------------------------------------
# 生产环境
# ------------------------------------------
/build

# ------------------------------------------
# 杂项
# ------------------------------------------
.DS_Store
*.pem
Thumbs.db

# ------------------------------------------
# 调试日志
# ------------------------------------------
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ------------------------------------------
# 本地环境文件 (包含敏感信息)
# ------------------------------------------
.env
.env*.local
.env.development
.env.test
.env.production

# ------------------------------------------
# Vercel 部署
# ------------------------------------------
.vercel

# ------------------------------------------
# TypeScript
# ------------------------------------------
*.tsbuildinfo
next-env.d.ts

# ------------------------------------------
# Prisma
# ------------------------------------------
/src/generated/prisma
prisma/*.db
prisma/*.db-journal

# ------------------------------------------
# 数据库文件
# ------------------------------------------
*.db
*.db-journal
*.sqlite
*.sqlite3

# ------------------------------------------
# 上传文件 (用户数据)
# ------------------------------------------
/uploads/
/public/uploads/

# ------------------------------------------
# Python 虚拟环境
# ------------------------------------------
/.venv/
/python-ocr/.venv/
/python-ocr/__pycache__/
/python-ocr/**/*.pyc
/python-ocr/**/*.pyo
/python-ocr/**/*.pyd
/python-ocr/.Python
/python-ocr/models/
/python-ocr/*.egg-info/
/python-ocr/.pytest_cache/
/python-ocr/.mypy_cache/

# ------------------------------------------
# IDE
# ------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~

# ------------------------------------------
# 临时文件
# ------------------------------------------
*.tmp
*.temp
.cache/
